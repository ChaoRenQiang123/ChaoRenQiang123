{
  "entities": {
    "Feedback": {
      "title": "User Feedback",
      "description": "Feedback submitted by users of the app",
      "type": "object",
      "properties": {
        "nickname": {
          "type": "string",
          "description": "The user's chosen nickname"
        },
        "content": {
          "type": "string",
          "description": "The feedback content"
        },
        "rating": {
          "type": "number",
          "description": "User's satisfaction rating (1-5)"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Server-side timestamp of when the feedback was created"
        }
      },
      "required": ["nickname", "content", "rating", "createdAt"]
    }
  },
  "firestore": {
    "feedbacks/{feedbackId}": {
      "schema": "Feedback",
      "description": "Collection of all user feedbacks"
    }
  }
}
